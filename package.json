{
  "name": "eyes-open-dementia-care",
  "version": "1.0.0",
  "description": "Privacy-conscious dementia care assistant with browser-side visual recognition, reminders, and gesture completion.",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "tsx server/index.ts",
    "build": "vite build && esbuild server/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist",
    "start": "node -e \"process.env.NODE_ENV='production'; import('./dist/index.js')\"",
    "check": "tsc",
    "test": "node --import tsx --test server/*.test.ts"
  },
